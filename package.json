{
  "name": "fax-lang",
  "version": "0.0.1",
  "description": "The Fax Programming Language Reference Implementation",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "fax": "./src/index.ts"
  },
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "docs:build": "cd book && mdbook build",
    "docs:serve": "cd book && mdbook serve"
  },
  "keywords": [
    "fax-lang",
    "compiler",
    "systems-programming",
    "state-machine",
    "memory-safe"
  ],
  "author": "Luvion1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luvion1/Fax-lang.git"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0"
  }
}
